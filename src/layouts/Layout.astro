---
import '../styles/global.css';
import DotGrid from '../components/DotGrid.astro';

interface Props {
	title: string;
	description?: string;
}

const { title, description = '개인 아카이브' } = Astro.props;
const currentPath = Astro.url.pathname;

const navItems = [
	{ href: '/', label: 'Home', exact: true, matches: ['/'] },
	{ href: '/work', label: 'Work', matches: ['/work', '/projects'] },
	{ href: '/about', label: 'About', matches: ['/about'] },
];
---

<html lang="ko">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width" />
		<meta name="description" content={description} />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>
	<body class="min-h-screen bg-[#1f1f1f] font-sans text-neutral-300 antialiased">
		<DotGrid />

		<a href="/" class="fixed left-6 top-6 z-30">
			<img src="/logo.svg" alt="FGMT" class="h-5 w-auto" />
		</a>

		<nav
			class="fixed left-1/2 top-6 z-30 flex -translate-x-1/2 items-center gap-1 rounded-full border border-white/10 bg-white/5 p-1.5 backdrop-blur"
		>
			{
				navItems.map((item) => {
					const isActive = item.exact
							? currentPath === item.href
							: item.matches.some((prefix) => currentPath.startsWith(prefix));
					return (
						<a
							href={item.href}
							class={`rounded-full px-4 py-1.5 text-sm font-medium transition ${
								isActive
									? 'bg-white/10 text-neutral-100'
									: 'text-neutral-400 hover:text-neutral-100'
							}`}
						>
							{item.label}
						</a>
					);
				})
			}
		</nav>

		<main class="mx-auto w-full max-w-4xl px-8 py-12">
			<slot />
		</main>
		<footer class="fixed bottom-6 left-1/2 z-30 -translate-x-1/2 text-sm text-neutral-500">
			© {new Date().getFullYear()} · ZEN archive
		</footer>
	</body>
</html>
