---
import '../styles/global.css';

interface Props {
	title: string;
	description?: string;
}

const { title, description = '개인 아카이브' } = Astro.props;
---

<html lang="ko">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width" />
		<meta name="description" content={description} />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>
	<body class="min-h-screen bg-neutral-950 text-neutral-100 antialiased">
		<header class="border-b border-neutral-800">
			<nav class="mx-auto flex max-w-5xl items-center justify-between px-6 py-5">
				<a href="/" class="text-sm font-semibold tracking-widest uppercase">FGMT</a>
				<div class="flex gap-6 text-sm text-neutral-400">
					<a href="/" class="hover:text-neutral-100">Work</a>
					<a href="/about" class="hover:text-neutral-100">About</a>
				</div>
			</nav>
		</header>
		<main class="mx-auto max-w-5xl px-6 py-12">
			<slot />
		</main>
		<footer class="mx-auto max-w-5xl px-6 py-10 text-sm text-neutral-500">
			© {new Date().getFullYear()} · Personal Archive
		</footer>
	</body>
</html>
