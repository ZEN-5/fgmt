---
import '../styles/global.css';
import DotGrid from '../components/DotGrid.astro';

interface Props {
	title: string;
	description?: string;
}

const { title, description = '개인 아카이브' } = Astro.props;
const currentPath = Astro.url.pathname;

const navItems = [
	{ href: '/', label: 'Work' },
	{ href: '/about', label: 'About' },
];
---

<html lang="ko">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width" />
		<meta name="description" content={description} />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>
	<body class="min-h-screen bg-[#1f1f1f] font-sans text-neutral-300 antialiased">
		<DotGrid />
		<div class="flex min-h-screen">
			<aside class="flex w-60 shrink-0 flex-col border-r border-white/10 px-4 py-6">
				<a href="/" class="px-2 text-sm font-semibold tracking-widest text-neutral-100 uppercase">
					FGMT
				</a>

				<p class="mt-8 px-2 text-xs font-medium tracking-wider text-neutral-500 uppercase">Menu</p>
				<nav class="mt-2 flex flex-col gap-1">
					{
						navItems.map((item) => {
							const isActive = item.href === '/' ? currentPath === '/' : currentPath.startsWith(item.href);
							return (
								<a
									href={item.href}
									class={`rounded-xl px-3 py-2 text-sm font-medium transition ${
										isActive
											? 'bg-white/10 text-neutral-100'
											: 'text-neutral-400 hover:bg-white/5 hover:text-neutral-100'
									}`}
								>
									{item.label}
								</a>
							);
						})
					}
				</nav>
			</aside>

			<div class="flex flex-1 flex-col">
				<main class="mx-auto w-full max-w-4xl flex-1 px-8 py-12">
					<slot />
				</main>
				<footer class="mx-auto w-full max-w-4xl px-8 py-8 text-sm text-neutral-500">
					© {new Date().getFullYear()} · Personal Archive
				</footer>
			</div>
		</div>
	</body>
</html>
