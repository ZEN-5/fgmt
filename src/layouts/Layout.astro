---
import '../styles/global.css';
import DotGrid from '../components/DotGrid.astro';

interface Props {
	title: string;
	description?: string;
}

const { title, description = '개인 아카이브' } = Astro.props;
const currentPath = Astro.url.pathname;

const navItems = [
	{ href: '/work', label: 'Work', matches: ['/work', '/projects'] },
	{ href: '/about', label: 'About', matches: ['/about'] },
];
---

<html lang="ko">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width" />
		<meta name="description" content={description} />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>
	<body class="min-h-screen bg-[#1f1f1f] font-sans text-neutral-300 antialiased">
		<DotGrid />

		<a href="/" class="fixed left-6 top-6 z-30">
			<img src="/logo.svg" alt="FGMT" class="h-5 w-auto" />
		</a>

		<button
			id="nav-toggle"
			type="button"
			aria-expanded="false"
			aria-controls="nav-panel"
			class="fixed left-1/2 top-6 z-30 -translate-x-1/2 rounded-full border border-white/10 bg-white/5 px-4 py-2 text-sm font-medium text-neutral-200 backdrop-blur transition hover:bg-white/10"
		>
			Menu
		</button>

		<div
			id="nav-overlay"
			class="pointer-events-none fixed inset-0 z-20 flex items-center justify-center bg-black/60 opacity-0 backdrop-blur-sm transition-opacity duration-200"
		>
			<nav
				id="nav-panel"
				class="scale-95 rounded-2xl border border-white/10 bg-[#1f1f1f] px-10 py-8 text-center shadow-2xl transition-transform duration-200"
			>
				<ul class="flex flex-col gap-2">
					{
						navItems.map((item) => {
							const isActive = item.matches.some((prefix) => currentPath.startsWith(prefix));
							return (
								<li>
									<a
										href={item.href}
										class={`block rounded-xl px-10 py-3 text-xl font-medium transition ${
											isActive ? 'text-neutral-100' : 'text-neutral-400 hover:text-neutral-100'
										}`}
									>
										{item.label}
									</a>
								</li>
							);
						})
					}
				</ul>
			</nav>
		</div>

		<main class="mx-auto w-full max-w-4xl px-8 py-12">
			<slot />
		</main>
		<footer class="fixed bottom-6 left-1/2 z-30 -translate-x-1/2 text-sm text-neutral-500">
			© {new Date().getFullYear()} · ZEN archive
		</footer>

		<script>
			const toggle = document.getElementById('nav-toggle');
			const overlay = document.getElementById('nav-overlay');
			const panel = document.getElementById('nav-panel');

			function openMenu() {
				overlay?.classList.remove('opacity-0', 'pointer-events-none');
				overlay?.classList.add('opacity-100');
				panel?.classList.remove('scale-95');
				panel?.classList.add('scale-100');
				toggle?.setAttribute('aria-expanded', 'true');
			}

			function closeMenu() {
				overlay?.classList.add('opacity-0', 'pointer-events-none');
				overlay?.classList.remove('opacity-100');
				panel?.classList.add('scale-95');
				panel?.classList.remove('scale-100');
				toggle?.setAttribute('aria-expanded', 'false');
			}

			toggle?.addEventListener('click', () => {
				const isOpen = toggle.getAttribute('aria-expanded') === 'true';
				if (isOpen) {
					closeMenu();
				} else {
					openMenu();
				}
			});

			overlay?.addEventListener('click', (e) => {
				if (e.target === overlay) closeMenu();
			});

			document.addEventListener('keydown', (e) => {
				if (e.key === 'Escape') closeMenu();
			});
		</script>
	</body>
</html>
