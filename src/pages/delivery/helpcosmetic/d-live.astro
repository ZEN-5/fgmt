---
import DeliveryLayout from '../../../layouts/DeliveryLayout.astro';

const base = '/deliveries/helpcosmetic';
const icons = `${base}/d-live/icons`;
---

<DeliveryLayout
	title="Type C - 수정사항 반영 (코드 구현) — 화장품 글로벌 규제조화 지원센터 홈페이지 구축"
	image={`${base}/thumbnailD.jpg`}
	fullBleed
>
	<a
		href="/delivery/helpcosmetic"
		class="fixed left-6 top-6 z-50 rounded-full bg-black/60 px-4 py-2 text-sm text-neutral-200 backdrop-blur hover:bg-black/80"
	>
		← 다른 시안 보기
	</a>

	<p
		class="fixed bottom-6 left-1/2 z-50 -translate-x-1/2 whitespace-nowrap rounded-full bg-black/60 px-4 py-2 text-xs text-neutral-200 backdrop-blur"
	>
		챗봇 · 퀵메뉴 버튼을 클릭 / 알림 아이콘에 마우스를 올려보세요 (position: fixed)
	</p>

	<div class="w-full bg-white text-[#111111]">
		<!-- GNB -->
		<header class="sticky top-0 z-30 w-full bg-white">
			<div class="h-[5px] w-full" style="background-image: linear-gradient(178.46deg, rgba(75,27,147,0.9) 0.44%, rgba(93,110,197,0.9) 80%), linear-gradient(90deg, #4b1b93 0%, #4b1b93 100%);"></div>
			<div class="flex h-[90px] w-full items-center justify-between border-b border-[#ebebeb] px-[30px]">
				<div class="whitespace-nowrap font-['Pretendard'] text-[16px] leading-[1.2] text-[#303030]">
					<p>화장품 글로벌</p>
					<p>규제조화 지원센터</p>
				</div>

				<nav class="hidden items-center gap-[50px] whitespace-nowrap text-[20px] leading-[1.5] lg:flex">
					<a href="#" class="font-bold text-[#2f35a9]">센터소개</a>
					<a href="#" class="font-medium text-[#111]">교육</a>
					<a href="#" class="font-medium text-[#111]">글로벌 규제정보</a>
					<a href="#" class="font-medium text-[#111]">국내외 원료 규제정보</a>
					<a href="#" class="font-medium text-[#111]">할랄 규제정보</a>
					<a href="#" class="font-medium text-[#111]">코스봇</a>
					<a href="#" class="font-medium text-[#111]">정부사업지원</a>
					<a href="#" class="font-medium text-[#111]">ICCR</a>
				</nav>

				<div class="flex items-center gap-[9px]">
					<div class="group relative flex items-center justify-center rounded-[6px] p-[10px]">
						<button type="button" aria-label="알림">
							<img src={`${icons}/bell.svg`} alt="" class="size-[24px]" />
						</button>
						<div
							class="pointer-events-none absolute left-1/2 top-full z-40 -translate-x-1/2 translate-y-1 opacity-0 transition-all duration-200 group-hover:translate-y-2 group-hover:opacity-100"
						>
							<div class="mx-auto h-[6px] w-[7px]">
								<img src={`${icons}/polygon.svg`} alt="" class="size-full rotate-180" />
							</div>
							<div class="whitespace-nowrap rounded-[8px] bg-[#5d31ff] px-[7px] py-[6px] text-center text-[12px] text-white shadow-[0px_4px_4px_rgba(0,0,0,0.25)]">
								자료 업데이트 알림서비스 신청
							</div>
						</div>
					</div>
					<button type="button" aria-label="전체 메뉴" class="flex items-center justify-center rounded-[6px] p-[10px]">
						<img src={`${icons}/hamburger-gnb.svg`} alt="" class="size-[28px]" />
					</button>
				</div>
			</div>
		</header>

		<!-- Section1 -->
		<section class="relative w-full bg-[#f3f4fa] py-10">
			<div class="mx-auto max-w-[1280px] px-4">
				<img src={`${base}/Section1.png`} alt="검색 및 바로가기" class="h-auto w-full" />
			</div>
		</section>

		<!-- Section2 -->
		<section class="w-full bg-white py-10">
			<div class="mx-auto max-w-[1280px] px-4">
				<img src={`${base}/Section2.png`} alt="해외법령" class="h-auto w-full" />
			</div>
		</section>

		<!-- Section3 -->
		<section class="w-full bg-[#f3f4fa] py-10">
			<div class="mx-auto max-w-[1280px] px-4">
				<img src={`${base}/Section3.png`} alt="인허가 대행사 및 해외 규정 요약 자료집" class="h-auto w-full" />
			</div>
		</section>

		<!-- Section4 -->
		<section class="w-full bg-white py-10">
			<div class="mx-auto max-w-[1280px] px-4">
				<img src={`${base}/Section4.png`} alt="해외동향정보지" class="h-auto w-full" />
			</div>
		</section>
	</div>

	<!-- Chatbot launcher (fixed) -->
	<button
		id="chatbot-btn"
		type="button"
		aria-label="챗봇 상담 열기"
		class="fixed z-40 size-[64px] transition-transform hover:scale-105"
		style="right: 148px; top: 178px;"
	>
		<img src={`${base}/chatbot.png`} alt="COS BOT" class="size-full" />
	</button>

	<!-- Chatbot panel (fixed, toggled) -->
	<div
		id="chatbot-panel"
		class="fixed z-40 hidden w-[340px] overflow-hidden rounded-2xl border border-[#e9ecf2] bg-white text-[#26282d] shadow-[0px_8px_30px_rgba(0,0,0,0.15)]"
		style="right: 148px; top: 250px;"
	>
		<div class="flex items-center justify-between bg-[#3b36bf] px-4 py-3">
			<span class="font-['Cafe24_PRO_UP:Regular'] text-[15px] text-white">COS BOT</span>
			<button id="chatbot-close" type="button" aria-label="챗봇 닫기" class="text-white/80 hover:text-white">✕</button>
		</div>
		<div class="flex h-[260px] flex-col gap-2 overflow-y-auto p-4 text-sm">
			<div class="max-w-[80%] rounded-xl rounded-tl-sm bg-[#f6f7f9] px-3 py-2">
				안녕하세요! 화장품 글로벌 규제 관련 궁금하신 점을 편하게 물어보세요.
			</div>
		</div>
		<div class="flex items-center gap-2 border-t border-[#e9ecf2] p-3">
			<input
				type="text"
				placeholder="메시지를 입력하세요"
				class="flex-1 rounded-full border border-[#e9ecf2] px-3 py-2 text-sm outline-none focus:border-[#3b36bf]"
			/>
			<button type="button" class="rounded-full bg-[#3b36bf] px-3 py-2 text-sm text-white">전송</button>
		</div>
	</div>

	<!-- Quick menu — closed state (fixed) -->
	<button
		id="quick-menu-closed"
		type="button"
		aria-label="퀵메뉴 열기"
		class="fixed z-40 flex items-center gap-1"
		style="right: 0px; top: 320px;"
	>
		<span class="-mr-[10px] size-5"><img src={`${icons}/closed1.svg`} alt="" class="size-full" /></span>
		<span class="-mr-[10px] size-5"><img src={`${icons}/closed2.svg`} alt="" class="size-full" /></span>
		<span class="size-5"><img src={`${icons}/closed3.svg`} alt="" class="size-full" /></span>
		<span
			class="flex h-[44px] w-[38px] items-center justify-center rounded-l-2xl border-b border-l border-t border-[#e2e4f1] bg-white py-5 pl-[10px] pr-[7px] drop-shadow-[0px_0px_10px_rgba(84,70,204,0.04)]"
		>
			<img src={`${icons}/hamburger.svg`} alt="" class="size-4" />
		</span>
	</button>

	<!-- Quick menu — open state (fixed) -->
	<div id="quick-menu-open" class="fixed z-40 hidden flex-col items-center gap-[10px]" style="right: 0px; top: 220px;">
		<div class="flex w-[90px] flex-col items-center justify-center rounded-l-[20px] border-b border-l border-t border-[#e9ecf2] bg-white py-5 shadow-[0px_4px_20px_0px_rgba(0,0,0,0.05)]">
			<div class="flex flex-col items-center gap-6">
				<a href="#" class="flex flex-col items-center gap-1">
					<span class="flex size-[30px] items-center justify-center rounded-full bg-[#f6f7f9]">
						<img src={`${icons}/globe.svg`} alt="" class="size-[18px]" />
					</span>
					<span class="text-center text-[13px] font-semibold tracking-[-0.13px] text-[#26282d]">해외법령</span>
				</a>
				<a href="#" class="flex flex-col items-center gap-1">
					<span class="flex size-[30px] items-center justify-center rounded-full bg-[#f6f7f9]">
						<img src={`${icons}/material.svg`} alt="" class="size-[14px]" />
					</span>
					<span class="text-center text-[13px] font-semibold leading-tight tracking-[-0.13px] text-[#26282d]">국내외 원료<br />규제정보</span>
				</a>
				<a href="#" class="flex flex-col items-center gap-1">
					<span class="flex size-[30px] items-center justify-center rounded-full bg-[#5d31ff]">
						<img src={`${icons}/chat.svg`} alt="" class="size-[15px]" />
					</span>
					<span class="text-center text-[13px] font-semibold tracking-[-0.13px] text-[#26282d]">챗봇상담</span>
				</a>
				<a href="#" class="flex flex-col items-center gap-1">
					<span class="flex size-[30px] items-center justify-center rounded-full bg-[#f6f7f9]">
						<img src={`${icons}/briefcase.svg`} alt="" class="size-[14px]" />
					</span>
					<span class="text-center text-[13px] font-semibold leading-tight tracking-[-0.13px] text-[#26282d]">정부지원<br />사업안내</span>
				</a>
				<a href="#" class="flex flex-col items-center gap-1">
					<span class="flex size-[30px] items-center justify-center rounded-full bg-[#f6f7f9]">
						<img src={`${icons}/globe2.svg`} alt="" class="size-[18px]" />
					</span>
					<span class="text-center text-[13px] font-semibold leading-tight tracking-[-0.13px] text-[#26282d]">세계법제<br />정보센터</span>
				</a>
			</div>
		</div>
		<button
			id="quick-menu-close"
			type="button"
			aria-label="퀵메뉴 닫기"
			class="flex size-[38px] items-center justify-center rounded-full border border-[#e9ecf2] bg-white drop-shadow-[0px_0px_10px_rgba(84,70,204,0.04)]"
		>
			<img src={`${icons}/close.svg`} alt="" class="size-5" />
		</button>
	</div>

	<script>
		const chatbotBtn = document.getElementById('chatbot-btn');
		const chatbotPanel = document.getElementById('chatbot-panel');
		const chatbotClose = document.getElementById('chatbot-close');

		chatbotBtn?.addEventListener('click', () => chatbotPanel?.classList.toggle('hidden'));
		chatbotClose?.addEventListener('click', () => chatbotPanel?.classList.add('hidden'));

		const quickClosed = document.getElementById('quick-menu-closed');
		const quickOpen = document.getElementById('quick-menu-open');
		const quickClose = document.getElementById('quick-menu-close');

		quickClosed?.addEventListener('click', () => {
			quickClosed.classList.add('hidden');
			quickOpen?.classList.remove('hidden');
			quickOpen?.classList.add('flex');
		});
		quickClose?.addEventListener('click', () => {
			quickOpen?.classList.add('hidden');
			quickOpen?.classList.remove('flex');
			quickClosed?.classList.remove('hidden');
		});
	</script>
</DeliveryLayout>
