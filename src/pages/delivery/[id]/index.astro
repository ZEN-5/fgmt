---
import { getCollection } from 'astro:content';
import DeliveryLayout from '../../../layouts/DeliveryLayout.astro';

export async function getStaticPaths() {
	const deliveries = await getCollection('deliveries');
	return deliveries.map((delivery) => ({
		params: { id: delivery.id },
		props: { delivery },
	}));
}

const { delivery } = Astro.props;
---

<DeliveryLayout title={`${delivery.data.title} — ${delivery.data.client}`}>
	<header class="mb-10">
		<p class="text-sm text-neutral-400">{delivery.data.client}</p>
		<h1 class="mt-1 text-2xl font-semibold tracking-tight">{delivery.data.title}</h1>
	</header>

	<div class="grid grid-cols-3 gap-4">
		{
			delivery.data.drafts.map((draft) => (
				<a
					href={`/delivery/${delivery.id}/${draft.slug}`}
					class="group block overflow-hidden rounded-xl border border-neutral-800 transition hover:border-neutral-600"
				>
					<img
						src={draft.thumbnail}
						alt={draft.label}
						class="w-full transition duration-300 group-hover:opacity-90"
					/>
				</a>
			))
		}
	</div>
</DeliveryLayout>
