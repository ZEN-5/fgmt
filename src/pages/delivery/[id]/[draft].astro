---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import DeliveryLayout from '../../../layouts/DeliveryLayout.astro';

export async function getStaticPaths() {
	const deliveries = await getCollection('deliveries');
	return deliveries.flatMap((delivery) =>
		delivery.data.drafts.map((draft) => ({
			params: { id: delivery.id, draft: draft.slug },
			props: { delivery, draft },
		}))
	);
}

const { delivery, draft } = Astro.props;
---

<DeliveryLayout title={`${draft.label} — ${delivery.data.title}`} fullBleed>
	<a
		href={`/delivery/${delivery.id}`}
		class="fixed left-6 top-6 z-10 rounded-full bg-black/60 px-4 py-2 text-sm text-neutral-200 backdrop-blur hover:bg-black/80"
	>
		← 다른 시안 보기
	</a>

	<p
		class="fixed bottom-6 left-1/2 z-10 -translate-x-1/2 whitespace-nowrap rounded-full bg-black/60 px-4 py-2 text-sm text-neutral-200 backdrop-blur"
	>
		이미지를 클릭하면 확대되고, 다시 클릭하면 다음 장으로 넘어갑니다 (<span id="counter">1</span> / {draft.images.length})
	</p>

	<div id="viewer" class="cursor-zoom-in select-none">
		{
			draft.images.map((img, i) => (
				<Image
					src={img}
					alt={`${draft.label} ${i + 1}`}
					data-slide={i}
					class={`mx-auto block max-h-screen max-w-full w-auto h-auto ${i === 0 ? '' : 'hidden'}`}
				/>
			))
		}
	</div>

	<script>
		const viewer = document.getElementById('viewer');
		const slides = viewer ? Array.from(viewer.querySelectorAll('img')) : [];
		const counter = document.getElementById('counter');
		const fitClasses = ['max-h-screen', 'max-w-full', 'w-auto', 'h-auto'];
		let index = 0;
		let zoomed = false;

		function overflowsViewport(img: HTMLImageElement) {
			return img.naturalWidth > window.innerWidth || img.naturalHeight > window.innerHeight;
		}

		viewer?.addEventListener('click', () => {
			if (slides.length === 0) return;
			const img = slides[index];

			if (!zoomed && overflowsViewport(img)) {
				img.classList.remove(...fitClasses);
				zoomed = true;
				viewer.classList.replace('cursor-zoom-in', 'cursor-zoom-out');
				return;
			}

			if (zoomed) {
				img.classList.add(...fitClasses);
				zoomed = false;
				viewer.classList.replace('cursor-zoom-out', 'cursor-zoom-in');
			}

			if (slides.length < 2) return;

			img.classList.add('hidden');
			index = (index + 1) % slides.length;
			slides[index].classList.remove('hidden');
			if (counter) counter.textContent = String(index + 1);
		});
	</script>
</DeliveryLayout>
