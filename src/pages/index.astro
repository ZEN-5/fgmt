---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import Layout from '../layouts/Layout.astro';

const projects = (await getCollection('projects')).sort(
	(a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
---

<Layout title="FGMT — Archive" description="개인 디자인 아카이브">
	<section class="mb-14">
		<h1 class="text-3xl font-semibold tracking-tight">Work</h1>
		<p class="mt-2 text-neutral-400">진행한 프로젝트와 작업물을 모아둔 아카이브입니다.</p>
	</section>

	<section class="grid grid-cols-1 gap-8 sm:grid-cols-2">
		{
			projects.map((project) => (
				<a
					href={`/projects/${project.id}`}
					class="group block overflow-hidden rounded-xl border border-neutral-800 bg-neutral-900 transition hover:border-neutral-600"
				>
					<div class="aspect-[3/2] overflow-hidden">
						<Image
							src={project.data.cover}
							alt={project.data.title}
							width={800}
							height={533}
							class="h-full w-full object-cover transition duration-300 group-hover:scale-105"
						/>
					</div>
					<div class="p-5">
						<h2 class="text-lg font-medium">{project.data.title}</h2>
						<p class="mt-1 text-sm text-neutral-400">{project.data.summary}</p>
						<div class="mt-3 flex flex-wrap gap-2">
							{project.data.tags.map((tag) => (
								<span class="rounded-full bg-neutral-800 px-2.5 py-1 text-xs text-neutral-300">
									{tag}
								</span>
							))}
						</div>
					</div>
				</a>
			))
		}
	</section>
</Layout>
